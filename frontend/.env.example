NEXT_PUBLIC_SANITY_PROJECT_ID="<paste your sanity project id here>" 
NEXT_PUBLIC_SANITY_DATASET="production" 
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-28" 
NEXT_PUBLIC_SANITY_STUDIO_URL="" 
# Optional: obscure path for Sanity Studio (e.g. cms-a8f3k2x9). If set, /studio is disabled and studio is only at /<this-value>.
SANITY_STUDIO_PATH=""
NEXT_PUBLIC_SANITY_STUDIO_PATH=""
# Optional: password required to access the studio when SANITY_STUDIO_PATH is set. Use a strong random string.
SANITY_STUDIO_ACCESS_SECRET=""
SANITY_API_READ_TOKEN="<paste your token here>"
# For analytics ingestion (page views, events, resume downloads). Can use same token if it has create permission.
SANITY_API_WRITE_TOKEN="<optional - falls back to READ_TOKEN if not set>"

# Cron - required for scheduled jobs crawl (Vercel sends "Authorization: Bearer <value>")
# CRON_SECRET=

# Jobs module - optional APIs (more sources = more jobs)
# THEMUSE_API_KEY=   # themuse.com/developers - 3600 req/hr
# ADZUNA_APP_ID=     # developer.adzuna.com - 19 countries
# ADZUNA_APP_KEY=
# USAJOBS_API_KEY=   # developer.usajobs.gov - US federal jobs

# SerpApi (Google Jobs) - optional, for location-based crawl. Free tier ~100 searches/mo.
# SERPAPI_KEY=

# Scraping (optional)
# SCRAPE_USER_AGENT="CrookedJobs/1.0 (https://yoursite.com; contact@yoursite.com)"
# SCRAPE_RATE_LIMIT_MS=2000
